{
  "expo": {
    "name": "Streaks",
    "slug": "streaks",
    "version": "0.1.0",
    "scheme": "streaks",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F1F0E4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rajat.streaks.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.rajat.streaks.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F1F0E4"
      },
      "permissions": [
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM",
        "NOTIFICATIONS",
        "POST_NOTIFICATIONS",
        "SCHEDULE_EXACT_ALARM"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#3E8C46",
          "defaultChannel": "habit-reminders",
          "sounds": []
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e9b4a6eb-08d8-4a6c-a36b-61695f912bdf"
      }
    },
    "owner": "rajat17",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/e9b4a6eb-08d8-4a6c-a36b-61695f912bdf"
    }
  }
}
